            .range-wrapper input[type=range]:not(:disabled)::-webkit-slider-thumb{background:#2563eb}
            .range-wrapper input[type=range]:not(:disabled)::-moz-range-thumb{background:#2563eb}
            @media screen and (max-width:768px){
                .tyc-modal{width:97vw!important;min-width:0!important;max-height:92vh!important;top:auto!important;left:auto!important;margin:0 auto!important}
                .tyc-grid{padding:7px;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));grid-auto-rows:128px;gap:6px}
                .tyc-header{padding:6px 8px;gap:4px}
